<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Admin Dashboard – LeaveEase</title>
  <link rel="stylesheet" href="/public/css/dashboard.css"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"/>
  <style>
    .stat-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:1.5rem; margin-top:2rem; }
    .stat-card  { background:#fff; border-radius:14px; padding:1.5rem 1.2rem; box-shadow:0 4px 16px var(--shadow-color); display:flex; flex-direction:column; gap:0.4rem; border-left:4px solid var(--primary-color); transition:transform 0.2s; }
    .stat-card:hover { transform:translateY(-3px); }
    .stat-card.pending  { border-color:#f59e0b; }
    .stat-card.approved { border-color:#10b981; }
    .stat-card.rejected { border-color:#ef4444; }
    .stat-card.employees{ border-color:#6366f1; }
    .stat-label { font-size:0.85rem; font-weight:600; color:#888; text-transform:uppercase; letter-spacing:0.05em; }
    .stat-value { font-size:2.4rem; font-weight:800; color:#1a1a1a; line-height:1; }
    .stat-icon  { font-size:1.6rem; margin-bottom:0.3rem; }
    .stat-card.pending  .stat-icon { color:#f59e0b; }
    .stat-card.approved .stat-icon { color:#10b981; }
    .stat-card.rejected .stat-icon { color:#ef4444; }
    .stat-card.employees .stat-icon { color:#6366f1; }
    .quick-actions { margin-top:2.5rem; }
    .quick-actions h3 { color:var(--primary-color); font-size:1.1rem; margin-bottom:1rem; font-weight:700; }
    .action-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:1rem; }
    .action-card { background:#fff; border-radius:12px; padding:1.2rem; box-shadow:0 2px 10px var(--shadow-color); text-align:center; cursor:pointer; transition:all 0.2s; text-decoration:none; color:inherit; display:block; }
    .action-card:hover { transform:translateY(-2px); box-shadow:0 6px 20px var(--shadow-color); }
    .action-card i { font-size:1.8rem; color:var(--primary-color); margin-bottom:0.5rem; display:block; }
    .action-card span { font-size:0.9rem; font-weight:600; color:#555; }
  </style>
</head>
<body>
<div class="dashboard-container">
  <%- include('partials/admin-sidebar', { active: 'dashboard' }) %>
  <div class="dashboard-main">
    <div class="dashboard-topbar">
      <div class="dashboard-welcome">
        <h3>Welcome back, <%= typeof session !== 'undefined' ? 'Admin' : 'Admin' %></h3>
        <p class="dashboard-date" id="adminDate"></p>
      </div>
      <div class="dashboard-icons">
        <button onclick="window.location.href='/admin-profile'" class="dashboard-icon-btn" title="Profile">
          <i class="fas fa-user-shield"></i>
        </button>
        <button onclick="logout()" class="dashboard-icon-btn" title="Logout">
          <i class="fas fa-sign-out-alt"></i>
        </button>
      </div>
    </div>

    <div class="stat-grid">
      <div class="stat-card employees">
        <div class="stat-icon"><i class="fas fa-users"></i></div>
        <div class="stat-label">Active Employees</div>
        <div class="stat-value"><%= typeof employeeCount !== 'undefined' ? employeeCount : '-' %></div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="color:var(--primary-color);"><i class="fas fa-calendar-alt"></i></div>
        <div class="stat-label">Total Requests</div>
        <div class="stat-value"><%= stats.total %></div>
      </div>
      <div class="stat-card pending">
        <div class="stat-icon"><i class="fas fa-clock"></i></div>
        <div class="stat-label">Pending</div>
        <div class="stat-value"><%= stats.pending %></div>
      </div>
      <div class="stat-card approved">
        <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
        <div class="stat-label">Approved</div>
        <div class="stat-value"><%= stats.approved %></div>
      </div>
      <div class="stat-card rejected">
        <div class="stat-icon"><i class="fas fa-times-circle"></i></div>
        <div class="stat-label">Rejected</div>
        <div class="stat-value"><%= stats.rejected %></div>
      </div>
    </div>

    <div class="quick-actions">
      <h3>Quick Actions</h3>
      <div class="action-grid">
        <a href="/admin/create-user" class="action-card">
          <i class="fas fa-user-plus"></i>
          <span>Add Employee</span>
        </a>
        <a href="/admin/users" class="action-card">
          <i class="fas fa-users-cog"></i>
          <span>Manage Employees</span>
        </a>
        <a href="/admin/leave-requests/pending" class="action-card">
          <i class="fas fa-calendar-check"></i>
          <span>Review Leaves</span>
        </a>
        <a href="/admin/logs" class="action-card">
          <i class="fas fa-list-alt"></i>
          <span>Audit Logs</span>
        </a>
      </div>
    </div>
  </div>
</div>
<script>
  function logout(){if(confirm('Are you sure you want to logout?'))window.location.href='/auth/logout';}
  document.getElementById('adminDate').textContent = new Date().toLocaleDateString('en-US',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
</script>
</body>
</html>
