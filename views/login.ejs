<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Login – LeaveEase</title>
  <link rel="stylesheet" href="/public/css/login-style.css"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"/>
  <style>
    .login-brand { display:flex; align-items:center; justify-content:center; gap:0.7rem; margin-bottom:1.8rem; }
    .login-brand-icon { background:#2e7d32; color:#fff; width:44px; height:44px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1.4rem; }
    .login-brand h1 { margin:0; font-size:1.9rem; font-weight:800; color:#1b5e20; letter-spacing:0.5px; }
    .login-brand h1 span { color:#66bb6a; }
    .login-subtitle { text-align:center; color:#666; font-size:0.92rem; margin-bottom:1.5rem; margin-top:-1rem; }
    .input-group { position:relative; margin-bottom:1.1rem; }
    .input-group i { position:absolute; left:0.9rem; top:50%; transform:translateY(-50%); color:#aaa; font-size:1rem; }
    .input-group input { padding-left:2.5rem; width:100%; box-sizing:border-box; }
    .error-box { background:#fff3f3; border:1.5px solid #ffcdd2; color:#c62828; border-radius:8px; padding:0.7rem 1rem; margin-bottom:1rem; font-size:0.93rem; display:flex; align-items:center; gap:0.5rem; }
    .login-footer { text-align:center; margin-top:1.2rem; font-size:0.9rem; color:#888; }
    .login-footer a { color:#2e7d32; font-weight:600; text-decoration:none; }
    .login-footer a:hover { text-decoration:underline; }
    .version-badge { position:fixed; bottom:1rem; right:1rem; background:#e8f5e9; color:#2e7d32; font-size:0.78rem; padding:0.3rem 0.7rem; border-radius:20px; font-weight:600; border:1px solid #c8e6c9; }
  </style>
</head>
<body>
  <div class="login-container">
    <div class="login-brand">
      <div class="login-brand-icon"><i class="fas fa-leaf"></i></div>
      <h1>Leave<span>Ease</span></h1>
    </div>
    <p class="login-subtitle">Employee Leave Management System</p>

    <% if (error) { %>
      <div class="error-box"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>

    <form action="/login" method="POST">
      <label for="email">Email Address</label>
      <div class="input-group">
        <i class="fas fa-envelope"></i>
        <input type="email" id="email" name="email" placeholder="you@company.com" required autocomplete="email"/>
      </div>

      <label for="password">Password</label>
      <div class="input-group">
        <i class="fas fa-lock"></i>
        <input type="password" id="password" name="password" placeholder="Enter your password" required autocomplete="current-password"/>
      </div>

      <div class="login-links">
        <a href="/forgot" class="forgot-link">Forgot Password?</a>
      </div>

      <button type="submit" class="cta-btn">
        <i class="fas fa-sign-in-alt"></i> Sign In
      </button>
    </form>

    <div class="login-footer">
      Contact your administrator to create an account.
    </div>
  </div>

  <div class="version-badge">v2.0 Professional</div>
</body>
</html>
